# Required ODPS / MaxCompute settings.
ALIBABA_CLOUD_ACCESS_KEY_ID=replace-with-readonly-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=replace-with-readonly-access-key-secret
ODPS_PROJECT=replace-with-maxcompute-project
ODPS_ENDPOINT=https://service.cn-beijing.maxcompute.aliyun.com/api

# Optional DataWorks read-only metadata lookup settings.
DATAWORKS_REGION=cn-beijing
DATAWORKS_PROJECT_ENV=PROD
DATAWORKS_API_VERSION=2020-05-18
DATAWORKS_ENDPOINT=dataworks.cn-beijing.aliyuncs.com
DATAWORKS_PROJECT_ID=
DATAWORKS_PROJECT_IDENTIFIER=
